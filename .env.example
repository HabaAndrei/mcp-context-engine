# Database Configuration
# Set CON_MCP_DB_TYPE to "sqlite" or "postgres" (defaults to "sqlite")
CON_MCP_DB_TYPE=sqlite

# PostgreSQL Configuration (used when CON_MCP_DB_TYPE=postgres)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=root1111
DB_NAME=abap-extension
DB_PORT=5432

# SQLite Configuration (used when CON_MCP_DB_TYPE=sqlite)
CON_MCP_SQLITE_PATH=./data.db

# CON_MCP_TRANSPORT stdio / http
CON_MCP_TRANSPORT=stdio